# ============================================
# Atican Beach Resort - Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- Supabase ---
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - NEVER expose to browser. Used only in server routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Paystack ---
# Get these from https://dashboard.paystack.com/#/settings/api
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# --- Resend (Email) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# --- App ---
# Your app's public URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000